<Window
    x:Class="PrintBit.Presentation.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:PrintBit.Presentation.Views"
    Title="PrintBit"
    Width="800"
    Height="750"
    Loaded="Window_Loaded"
    ResizeMode="CanResize"
    ShowInTaskbar="True"
    Topmost="False"
    Unloaded="Window_Unloaded"
    WindowState="Maximized"
    WindowStyle="SingleBorderWindow"
    mc:Ignorable="d">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#FFF4EEFF" />
                <GradientStop Offset="1" Color="#FFEAF5FF" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:Card Margin="0,0,0,16" Padding="16">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            VerticalAlignment="Center"
                            Kind="PrinterPos" />
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock
                                FontSize="26"
                                FontWeight="SemiBold"
                                Text="{Binding CurrentScreenTitle}" />
                            <TextBlock Opacity="0.75" Text="Self-service Print, Copy, and Scan Kiosk" />
                        </StackPanel>
                    </StackPanel>

                    <Button
                        Width="130"
                        Margin="20,0,0,0"
                        Padding="10,6"
                        Command="{Binding ShowLandingCommand}"
                        Content="Back to Home"
                        DockPanel.Dock="Right"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                </DockPanel>
            </materialDesign:Card>

            <Border
                Grid.Row="1"
                Padding="12"
                Background="#CCFFFFFF"
                BorderBrush="#22000000"
                BorderThickness="1"
                CornerRadius="14">
                <Grid>
                    <views:LandingView Visibility="{Binding IsLandingScreen, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <views:PrintView Visibility="{Binding IsPrintScreen, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <views:CopyView Visibility="{Binding IsCopyScreen, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <views:PrintConfigurationView Visibility="{Binding IsPrintConfigurationScreen, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <views:ConfirmPrintView Visibility="{Binding IsConfirmPrintScreen, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
