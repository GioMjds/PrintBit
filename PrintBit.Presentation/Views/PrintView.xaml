<UserControl
    x:Class="PrintBit.Presentation.Views.PrintView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.35*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card
            Grid.Column="0"
            Margin="8"
            Padding="16">
            <StackPanel>
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Offline-First Wireless Upload" />
                <TextBlock
                    Margin="0,8,0,0"
                    FontSize="13"
                    Text="{Binding OfflineGuidanceMessage}"
                    TextWrapping="Wrap" />

                <Border
                    Margin="0,12,0,0"
                    Padding="12"
                    BorderBrush="#FFBBBBBB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding IsUploadQrVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Height="220">
                        <Rectangle
                            Fill="#FFE8E8E8"
                            RadiusX="8"
                            RadiusY="8" />
                        <Image
                            Margin="8"
                            Source="{Binding WirelessQrCodeImage}"
                            Stretch="Uniform" />
                    </Grid>
                </Border>

                <TextBlock
                    Margin="0,10,0,0"
                    FontSize="13"
                    Text="{Binding SessionCountdownText}"
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,6,0,0"
                    FontSize="13"
                    Text="{Binding WirelessUploadStatus}"
                    TextWrapping="Wrap" />
                <TextBox
                    Margin="0,8,0,0"
                    IsReadOnly="True"
                    Text="{Binding WirelessUploadUrl, Mode=OneWay}"
                    Visibility="{Binding IsUploadQrVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding StartWirelessSessionCommand}"
                        Content="Refresh QR Session" />
                    <Button
                        Command="{Binding UseUsbFallbackCommand}"
                        Content="Use USB Fallback"
                        Visibility="{Binding IsFallbackActionsVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card
            Grid.Column="1"
            Margin="8"
            Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Uploaded Files" />

                <ListBox
                    Grid.Row="1"
                    Margin="0,12,0,12"
                    ItemsSource="{Binding UploadedFiles}"
                    SelectedItem="{Binding SelectedUploadedFile, Mode=TwoWay}" />

                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Padding="10,6"
                        Command="{Binding GoBackToLandingCommand}"
                        Content="Back" />
                    <Button
                        Padding="10,6"
                        Command="{Binding ContinueToConfigurationCommand}"
                        Content="Continue" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
