<UserControl
    x:Class="PrintBit.Presentation.Views.PrintView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card
            Grid.Column="0"
            Margin="8"
            Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel Visibility="{Binding IsHotspotGuideVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Step 1 (Required): Scan to join kiosk network" />
                        <TextBlock
                            Margin="0,4,0,6"
                            Text="{Binding OfflineGuidanceMessage}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,0,0,10"
                            Foreground="#AA000000"
                            Text="No internet needed. Keep your phone on kiosk network Wi-Fi." />
                        <TextBlock
                            Margin="0,0,0,10"
                            FontSize="11"
                            Foreground="#66000000"
                            Text="{Binding NetworkDiagnosticsText}"
                            TextWrapping="Wrap" />

                        <Border
                            Padding="8"
                            BorderBrush="#33000000"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid Height="220">
                                <Image
                                    Source="{Binding HotspotQrCodeImage}"
                                    Stretch="Uniform" />
                            </Grid>
                        </Border>

                        <TextBlock Margin="0,10,0,0" Text="{Binding HotspotSsid, StringFormat=SSID: {0}}" />
                        <TextBlock Margin="0,2,0,0" Text="{Binding HotspotPassword, StringFormat=Password: {0}}" />

                        <StackPanel
                            Margin="0,12,0,0"
                            Orientation="Horizontal">
                            <Button
                                Margin="0,0,8,0"
                                Padding="10,6"
                                Command="{Binding ConfirmPhoneConnectedCommand}"
                                Content="Connected - Continue" />
                            <Button
                                Margin="0,0,8,0"
                                Padding="10,6"
                                Command="{Binding RetryPhoneConnectionCommand}"
                                Content="Retry"
                                Visibility="{Binding IsFallbackActionsVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button
                                Padding="10,6"
                                Command="{Binding UseUsbFallbackCommand}"
                                Content="Use USB Fallback"
                                Visibility="{Binding IsFallbackActionsVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel
                        Margin="0,16,0,0"
                        Visibility="{Binding IsUploadQrVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Step 2: Scan upload QR (offline)" />
                        <TextBlock
                            Margin="0,6,0,10"
                            Text="{Binding WirelessUploadStatus}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,0,0,10"
                            FontSize="11"
                            Foreground="#66000000"
                            Text="{Binding NetworkDiagnosticsText}"
                            TextWrapping="Wrap" />

                        <Border
                            Padding="8"
                            BorderBrush="#33000000"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid Height="320">
                                <Image
                                    Source="{Binding WirelessQrCodeImage}"
                                    Stretch="Uniform" />
                            </Grid>
                        </Border>

                        <TextBlock
                            Margin="0,8,0,0"
                            Foreground="#AA000000"
                            Text="{Binding SessionCountdownText}" />
                        <TextBox
                            Margin="0,8,0,0"
                            IsReadOnly="True"
                            Text="{Binding WirelessUploadUrl, Mode=OneWay}"
                            Visibility="{Binding HasWirelessUploadUrl, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button
                            Margin="0,10,0,0"
                            HorizontalAlignment="Right"
                            Padding="10,6"
                            Command="{Binding StartWirelessSessionCommand}"
                            Content="Refresh QR" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </materialDesign:Card>

        <materialDesign:Card
            Grid.Column="1"
            Margin="8"
            Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    FontSize="23"
                    FontWeight="Bold"
                    Text="Uploaded Files" />

                <ListBox
                    Grid.Row="1"
                    Margin="0,12,0,12"
                    ItemsSource="{Binding UploadedFiles}"
                    SelectedItem="{Binding SelectedUploadedFile, Mode=TwoWay}" />

                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="78"
                        Margin="0,0,8,0"
                        Padding="10,6"
                        Command="{Binding GoBackToLandingCommand}"
                        Content="Back" />
                    <Button
                        Padding="10,6"
                        Command="{Binding ContinueToConfigurationCommand}"
                        Content="Continue" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
