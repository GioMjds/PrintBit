<UserControl
    x:Class="PrintBit.Presentation.Views.LandingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,20">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="24"
                FontWeight="SemiBold"
                Text="Landing Screen" />

            <StackPanel
                Margin="20,0,0,0"
                DockPanel.Dock="Right"
                Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Padding="5"
                    Command="{Binding OpenSettingsCommand}">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        Kind="Cog" />
                </Button>
                <Button Padding="5" Command="{Binding PowerOffCommand}">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        Kind="Power" />
                </Button>
            </StackPanel>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="3">
            <materialDesign:Card Margin="8" Padding="20">
                <StackPanel VerticalAlignment="Center">
                    <materialDesign:PackIcon
                        Width="56"
                        Height="56"
                        HorizontalAlignment="Center"
                        Kind="Printer" />
                    <TextBlock
                        Margin="0,12,0,12"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Print" />
                    <Button
                        Padding="5"
                        Command="{Binding OpenPrintCommand}"
                        Content="Open Print" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="8" Padding="20">
                <StackPanel VerticalAlignment="Center">
                    <materialDesign:PackIcon
                        Width="56"
                        Height="56"
                        HorizontalAlignment="Center"
                        Kind="ContentCopy" />
                    <TextBlock
                        Margin="0,12,0,12"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Copy" />
                    <Button
                        Padding="5"
                        Command="{Binding OpenCopyCommand}"
                        Content="Open Copy" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="8" Padding="20">
                <StackPanel VerticalAlignment="Center">
                    <materialDesign:PackIcon
                        Width="56"
                        Height="56"
                        HorizontalAlignment="Center"
                        Kind="Scanner" />
                    <TextBlock
                        Margin="0,12,0,12"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Scan" />
                    <Button
                        Padding="5"
                        Command="{Binding OpenScanCommand}"
                        Content="Open Scan" />
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>
    </Grid>
</UserControl>
